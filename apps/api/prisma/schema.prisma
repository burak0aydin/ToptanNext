generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  passwordHash        String
  role                Role                 @default(BUYER)
  isVerified          Boolean              @default(false)
  isActive            Boolean              @default(true)
  deletedAt           DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  fullName            String?
  firstName           String?
  lastName            String?
  phoneNumber         String?
  supplierApplication SupplierApplication?
  productListings     ProductListing[]

  @@index([email])
  @@index([role])
  @@map("users")
}

model SupplierApplication {
  id                          String                          @id @default(cuid())
  userId                      String                          @unique @map("user_id")
  companyName                 String                          @map("company_name")
  companyType                 SupplierCompanyType             @map("company_type")
  vknOrTckn                   String                          @map("vkn_or_tckn")
  taxOffice                   String                          @map("tax_office")
  mersisNo                    String                          @map("mersis_no")
  tradeRegistryNo             String?                         @map("trade_registry_no")
  activitySector              String                          @map("activity_sector")
  createdAt                   DateTime                        @default(now()) @map("created_at")
  updatedAt                   DateTime                        @updatedAt @map("updated_at")
  city                        String                          @map("city")
  district                    String                          @map("district")
  referenceCode               String?                         @map("reference_code")
  businessPhone               String?                         @map("business_phone")
  companyIban                 String?                         @map("company_iban")
  contactEmail                String?                         @map("contact_email")
  contactFirstName            String?                         @map("contact_first_name")
  contactLastName             String?                         @map("contact_last_name")
  contactPhone                String?                         @map("contact_phone")
  contactRole                 String?                         @map("contact_role")
  headquartersAddress         String?                         @map("headquarters_address")
  isEInvoiceTaxpayer          Boolean?                        @map("is_e_invoice_taxpayer")
  kepAddress                  String?                         @map("kep_address")
  reviewNote                  String?                         @map("review_note")
  reviewStatus                SupplierApplicationReviewStatus @default(PENDING) @map("review_status")
  reviewedAt                  DateTime?                       @map("reviewed_at")
  warehouseAddress            String?                         @map("warehouse_address")
  warehouseSameAsHeadquarters Boolean?                        @map("warehouse_same_as_headquarters")
  approvedCommercialMessage   Boolean                         @default(false) @map("approved_commercial_message")
  approvedKvkkAgreement       Boolean                         @default(false) @map("approved_kvkk_agreement")
  approvedSupplierAgreement   Boolean                         @default(false) @map("approved_supplier_agreement")
  documents                   SupplierApplicationDocument[]
  user                        User                            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyType])
  @@index([activitySector])
  @@index([reviewStatus])
  @@map("supplier_applications")
}

model SupplierApplicationDocument {
  id                    String                          @id @default(cuid())
  supplierApplicationId String                          @map("supplier_application_id")
  documentType          SupplierApplicationDocumentType @map("document_type")
  originalName          String                          @map("original_name")
  filePath              String                          @map("file_path")
  mimeType              String                          @map("mime_type")
  fileSize              Int                             @map("file_size")
  uploadedAt            DateTime                        @default(now()) @map("uploaded_at")
  updatedAt             DateTime                        @updatedAt @map("updated_at")
  supplierApplication   SupplierApplication             @relation(fields: [supplierApplicationId], references: [id], onDelete: Cascade)

  @@unique([supplierApplicationId, documentType])
  @@index([documentType])
  @@map("supplier_application_documents")
}

model Category {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  level     Int
  parentId  String?    @map("parent_id")
  sortOrder Int        @default(0) @map("sort_order")
  isActive  Boolean    @default(true) @map("is_active")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  parent    Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children  Category[] @relation("CategoryHierarchy")
  products  Product[]
  productListings ProductListing[]

  @@index([level])
  @@index([parentId])
  @@index([isActive])
  @@map("categories")
}

model Sector {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  sortOrder Int       @unique(map: "sectors_sort_order_unique") @default(0) @map("sort_order")
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  products  Product[]
  productListingSectors ProductListingSector[]

  @@index([isActive])
  @@map("sectors")
}

model Product {
  id         String   @id @default(cuid())
  name       String
  slug       String   @unique
  categoryId String   @map("category_id")
  sectorId   String?  @map("sector_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  category   Category @relation(fields: [categoryId], references: [id])
  sector     Sector?  @relation(fields: [sectorId], references: [id])

  @@index([categoryId])
  @@index([sectorId])
  @@map("products")
}

model ProductListing {
  id                String               @id @default(cuid())
  supplierId        String               @map("supplier_id")
  name              String
  slug              String
  sku               String
  description       String               @db.Text
  categoryId        String               @map("category_id")
  status            ProductListingStatus @default(DRAFT)
  featuredFeatures  String[]             @default([]) @map("featured_features")
  isCustomizable    Boolean              @default(false) @map("is_customizable")
  customizationNote String?              @map("customization_note")
  basePrice         Decimal?             @db.Decimal(12, 2) @map("base_price")
  currency          String               @default("TRY")
  minOrderQuantity  Int?                 @map("min_order_quantity")
  stock             Int?
  isNegotiationEnabled Boolean           @default(false) @map("is_negotiation_enabled")
  negotiationThreshold Int?              @map("negotiation_threshold")
  pricingTiers      Json                 @default("[]") @map("pricing_tiers")
  leadTimeDays      Int?                 @map("lead_time_days")
  packageLengthCm   Decimal?             @db.Decimal(8, 2) @map("package_length_cm")
  packageWidthCm    Decimal?             @db.Decimal(8, 2) @map("package_width_cm")
  packageHeightCm   Decimal?             @db.Decimal(8, 2) @map("package_height_cm")
  packageWeightKg   Decimal?             @db.Decimal(8, 3) @map("package_weight_kg")
  submittedAt       DateTime?            @map("submitted_at")
  reviewNote        String?              @map("review_note")
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")
  deletedAt         DateTime?            @map("deleted_at")
  supplier          User                 @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  category          Category             @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  sectors           ProductListingSector[]
  media             ProductListingMedia[]

  @@unique([supplierId, sku])
  @@unique([supplierId, slug])
  @@index([supplierId])
  @@index([status])
  @@index([categoryId])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("product_listings")
}

model ProductListingSector {
  id               String         @id @default(cuid())
  productListingId String         @map("product_listing_id")
  sectorId         String         @map("sector_id")
  createdAt        DateTime       @default(now()) @map("created_at")
  productListing   ProductListing @relation(fields: [productListingId], references: [id], onDelete: Cascade)
  sector           Sector         @relation(fields: [sectorId], references: [id], onDelete: Restrict)

  @@unique([productListingId, sectorId])
  @@index([sectorId])
  @@map("product_listing_sectors")
}

model ProductListingMedia {
  id               String                  @id @default(cuid())
  productListingId String                  @map("product_listing_id")
  mediaType        ProductListingMediaType @default(IMAGE) @map("media_type")
  filePath         String                  @map("file_path")
  originalName     String                  @map("original_name")
  mimeType         String                  @map("mime_type")
  fileSize         Int                     @map("file_size")
  displayOrder     Int                     @default(0) @map("display_order")
  createdAt        DateTime                @default(now()) @map("created_at")
  updatedAt        DateTime                @updatedAt @map("updated_at")
  productListing   ProductListing          @relation(fields: [productListingId], references: [id], onDelete: Cascade)

  @@index([productListingId, displayOrder])
  @@map("product_listing_media")
}

enum Role {
  ADMIN
  SUPPLIER
  BUYER
}

enum SupplierCompanyType {
  SAHIS
  LIMITED
  ANONIM
}

enum SupplierApplicationReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SupplierApplicationDocumentType {
  TAX_CERTIFICATE
  SIGNATURE_CIRCULAR
  TRADE_REGISTRY_GAZETTE
  ACTIVITY_CERTIFICATE
}

enum ProductListingStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum ProductListingMediaType {
  IMAGE
  VIDEO
}
