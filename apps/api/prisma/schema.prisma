generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  passwordHash        String
  role                Role                 @default(BUYER)
  isLogisticsPartner  Boolean              @default(false) @map("is_logistics_partner")
  companyName         String?              @map("company_name")
  avatarUrl           String?              @map("avatar_url")
  isVerified          Boolean              @default(false)
  isActive            Boolean              @default(true)
  deletedAt           DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  fullName            String?
  firstName           String?
  lastName            String?
  phoneNumber         String?
  supplierApplication SupplierApplication?
  logisticsApplication LogisticsApplication?
  productListings     ProductListing[]
  conversationParticipants ConversationParticipant[]
  sentMessages        Message[]            @relation("UserSentMessages")
  cartItems           CartItem[]           @relation("UserCartItems")

  @@index([email])
  @@index([role])
  @@map("users")
}

model SupplierApplication {
  id                          String                          @id @default(cuid())
  userId                      String                          @unique @map("user_id")
  companyName                 String                          @map("company_name")
  companyType                 SupplierCompanyType             @map("company_type")
  vknOrTckn                   String                          @map("vkn_or_tckn")
  taxOffice                   String                          @map("tax_office")
  mersisNo                    String                          @map("mersis_no")
  tradeRegistryNo             String?                         @map("trade_registry_no")
  activitySector              String                          @map("activity_sector")
  createdAt                   DateTime                        @default(now()) @map("created_at")
  updatedAt                   DateTime                        @updatedAt @map("updated_at")
  city                        String                          @map("city")
  district                    String                          @map("district")
  referenceCode               String?                         @map("reference_code")
  businessPhone               String?                         @map("business_phone")
  companyIban                 String?                         @map("company_iban")
  contactEmail                String?                         @map("contact_email")
  contactFirstName            String?                         @map("contact_first_name")
  contactLastName             String?                         @map("contact_last_name")
  contactPhone                String?                         @map("contact_phone")
  contactRole                 String?                         @map("contact_role")
  headquartersAddress         String?                         @map("headquarters_address")
  isEInvoiceTaxpayer          Boolean?                        @map("is_e_invoice_taxpayer")
  kepAddress                  String?                         @map("kep_address")
  reviewNote                  String?                         @map("review_note")
  reviewStatus                SupplierApplicationReviewStatus @default(PENDING) @map("review_status")
  reviewedAt                  DateTime?                       @map("reviewed_at")
  warehouseAddress            String?                         @map("warehouse_address")
  warehouseSameAsHeadquarters Boolean?                        @map("warehouse_same_as_headquarters")
  approvedCommercialMessage   Boolean                         @default(false) @map("approved_commercial_message")
  approvedKvkkAgreement       Boolean                         @default(false) @map("approved_kvkk_agreement")
  approvedSupplierAgreement   Boolean                         @default(false) @map("approved_supplier_agreement")
  documents                   SupplierApplicationDocument[]
  user                        User                            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyType])
  @@index([activitySector])
  @@index([reviewStatus])
  @@map("supplier_applications")
}

model SupplierApplicationDocument {
  id                    String                          @id @default(cuid())
  supplierApplicationId String                          @map("supplier_application_id")
  documentType          SupplierApplicationDocumentType @map("document_type")
  originalName          String                          @map("original_name")
  filePath              String                          @map("file_path")
  mimeType              String                          @map("mime_type")
  fileSize              Int                             @map("file_size")
  uploadedAt            DateTime                        @default(now()) @map("uploaded_at")
  updatedAt             DateTime                        @updatedAt @map("updated_at")
  supplierApplication   SupplierApplication             @relation(fields: [supplierApplicationId], references: [id], onDelete: Cascade)

  @@unique([supplierApplicationId, documentType])
  @@index([documentType])
  @@map("supplier_application_documents")
}

model LogisticsApplication {
  id                                  String                           @id @default(cuid())
  userId                              String                           @unique @map("user_id")
  companyName                         String                           @map("company_name")
  companyType                         SupplierCompanyType              @map("company_type")
  vknOrTckn                           String                           @map("vkn_or_tckn")
  taxOffice                           String                           @map("tax_office")
  mersisNo                            String                           @map("mersis_no")
  tradeRegistryNo                     String?                          @map("trade_registry_no")
  city                                String                           @map("city")
  district                            String                           @map("district")
  referenceCode                       String?                          @map("reference_code")
  logisticsAuthorizationDocumentType  LogisticsAuthorizationDocumentType @map("logistics_authorization_document_type")
  mainServiceTypes                    LogisticsMainServiceType[]       @default([]) @map("main_service_types")
  companyIban                         String?                          @map("company_iban")
  kepAddress                          String?                          @map("kep_address")
  isEInvoiceTaxpayer                  Boolean?                         @map("is_e_invoice_taxpayer")
  businessPhone                       String?                          @map("business_phone")
  headquartersAddress                 String?                          @map("headquarters_address")
  serviceRegions                      LogisticsServiceRegion[]         @default([]) @map("service_regions")
  fleetCapacity                       LogisticsFleetCapacity?          @map("fleet_capacity")
  contactFirstName                    String?                          @map("contact_first_name")
  contactLastName                     String?                          @map("contact_last_name")
  contactRole                         String?                          @map("contact_role")
  contactPhone                        String?                          @map("contact_phone")
  contactEmail                        String?                          @map("contact_email")
  reviewStatus                        LogisticsApplicationReviewStatus @default(PENDING) @map("review_status")
  reviewNote                          String?                          @map("review_note")
  reviewedAt                          DateTime?                        @map("reviewed_at")
  approvedCommercialMessage           Boolean                          @default(false) @map("approved_commercial_message")
  approvedKvkkAgreement               Boolean                          @default(false) @map("approved_kvkk_agreement")
  approvedSupplierAgreement           Boolean                          @default(false) @map("approved_supplier_agreement")
  createdAt                           DateTime                         @default(now()) @map("created_at")
  updatedAt                           DateTime                         @updatedAt @map("updated_at")
  documents                           LogisticsApplicationDocument[]
  user                                User                             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyType])
  @@index([reviewStatus])
  @@index([logisticsAuthorizationDocumentType])
  @@map("logistics_applications")
}

model LogisticsApplicationDocument {
  id                    String                            @id @default(cuid())
  logisticsApplicationId String                           @map("logistics_application_id")
  documentType          LogisticsApplicationDocumentType  @map("document_type")
  originalName          String                            @map("original_name")
  filePath              String                            @map("file_path")
  mimeType              String                            @map("mime_type")
  fileSize              Int                               @map("file_size")
  uploadedAt            DateTime                          @default(now()) @map("uploaded_at")
  updatedAt             DateTime                          @updatedAt @map("updated_at")
  logisticsApplication  LogisticsApplication              @relation(fields: [logisticsApplicationId], references: [id], onDelete: Cascade)

  @@unique([logisticsApplicationId, documentType])
  @@index([documentType])
  @@map("logistics_application_documents")
}

model Category {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  level     Int
  parentId  String?    @map("parent_id")
  sortOrder Int        @default(0) @map("sort_order")
  isActive  Boolean    @default(true) @map("is_active")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  parent    Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children  Category[] @relation("CategoryHierarchy")
  products  Product[]
  productListings ProductListing[]

  @@index([level])
  @@index([parentId])
  @@index([isActive])
  @@map("categories")
}

model Sector {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  sortOrder Int       @unique(map: "sectors_sort_order_unique") @default(0) @map("sort_order")
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  products  Product[]
  productListingSectors ProductListingSector[]

  @@index([isActive])
  @@map("sectors")
}

model Product {
  id         String   @id @default(cuid())
  name       String
  slug       String   @unique
  categoryId String   @map("category_id")
  sectorId   String?  @map("sector_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  category   Category @relation(fields: [categoryId], references: [id])
  sector     Sector?  @relation(fields: [sectorId], references: [id])

  @@index([categoryId])
  @@index([sectorId])
  @@map("products")
}

model ProductListing {
  id                String               @id @default(cuid())
  supplierId        String               @map("supplier_id")
  name              String
  slug              String
  sku               String
  description       String               @db.Text
  categoryId        String               @map("category_id")
  status            ProductListingStatus @default(DRAFT)
  isActive          Boolean              @default(true) @map("is_active")
  featuredFeatures  String[]             @default([]) @map("featured_features")
  isCustomizable    Boolean              @default(false) @map("is_customizable")
  customizationNote String?              @map("customization_note")
  variantGroups     Json                 @default("[]") @map("variant_groups")
  basePrice         Decimal?             @db.Decimal(12, 2) @map("base_price")
  currency          String               @default("TRY")
  minOrderQuantity  Int?                 @map("min_order_quantity")
  stock             Int?
  isNegotiationEnabled Boolean           @default(false) @map("is_negotiation_enabled")
  negotiationThreshold Int?              @map("negotiation_threshold")
  pricingTiers      Json                 @default("[]") @map("pricing_tiers")
  packageType       ProductListingPackageType? @map("package_type")
  leadTimeDays      Int?                 @map("lead_time_days")
  shippingTime      ProductListingShippingTime? @map("shipping_time")
  deliveryMethods   ProductListingDeliveryMethod[] @default([]) @map("delivery_methods")
  dynamicFreightAgreement Boolean        @default(false) @map("dynamic_freight_agreement")
  packageLengthCm   Decimal?             @db.Decimal(8, 2) @map("package_length_cm")
  packageWidthCm    Decimal?             @db.Decimal(8, 2) @map("package_width_cm")
  packageHeightCm   Decimal?             @db.Decimal(8, 2) @map("package_height_cm")
  packageWeightKg   Decimal?             @db.Decimal(8, 3) @map("package_weight_kg")
  submittedAt       DateTime?            @map("submitted_at")
  reviewNote        String?              @map("review_note")
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")
  deletedAt         DateTime?            @map("deleted_at")
  supplier          User                 @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  category          Category             @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  sectors           ProductListingSector[]
  media             ProductListingMedia[]
  conversations     Conversation[]
  quotes            Quote[]
  cartItems         CartItem[]

  @@unique([supplierId, sku])
  @@unique([supplierId, slug])
  @@index([supplierId])
  @@index([status])
  @@index([categoryId])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("product_listings")
}

model CartItem {
  id               String         @id @default(cuid())
  buyerId          String         @map("buyer_id")
  productListingId String         @map("product_listing_id")
  quantity         Int            @default(1)
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  buyer            User           @relation("UserCartItems", fields: [buyerId], references: [id], onDelete: Cascade)
  productListing   ProductListing @relation(fields: [productListingId], references: [id], onDelete: Cascade)

  @@unique([buyerId, productListingId])
  @@index([buyerId])
  @@index([productListingId])
  @@map("cart_items")
}

model Conversation {
  id               String                    @id @default(cuid())
  productListingId String?                   @map("product_listing_id")
  lastMessageAt    DateTime                  @default(now()) @map("last_message_at")
  status           ConversationStatus        @default(ACTIVE)
  createdAt        DateTime                  @default(now()) @map("created_at")
  updatedAt        DateTime                  @updatedAt @map("updated_at")
  productListing   ProductListing?           @relation(fields: [productListingId], references: [id], onDelete: SetNull)
  participants     ConversationParticipant[]
  messages         Message[]

  @@index([lastMessageAt])
  @@index([status])
  @@index([productListingId])
  @@map("conversations")
}

model ConversationParticipant {
  conversationId String       @map("conversation_id")
  userId         String       @map("user_id")
  unreadCount    Int          @default(0) @map("unread_count")
  lastReadAt     DateTime     @default(now()) @map("last_read_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
  @@index([userId, unreadCount])
  @@map("conversation_participants")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String       @map("conversation_id")
  senderId       String       @map("sender_id")
  type           MessageType
  body           String?      @db.Text
  isEdited       Boolean      @default(false) @map("is_edited")
  deletedAt      DateTime?    @map("deleted_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("UserSentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  attachments    Attachment[]
  quote          Quote?

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@index([deletedAt])
  @@map("messages")
}

model Attachment {
  id        String   @id @default(cuid())
  messageId String   @map("message_id")
  fileName  String   @map("file_name")
  fileUrl   String   @map("file_url")
  fileSize  Int      @map("file_size")
  mimeType  String   @map("mime_type")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@map("attachments")
}

model Quote {
  id             String   @id @default(cuid())
  messageId      String   @unique @map("message_id")
  productListingId String @map("product_listing_id")
  quantity       Int
  unitPrice      Decimal  @db.Decimal(12, 2) @map("unit_price")
  logisticsFee   Decimal? @db.Decimal(12, 2) @map("logistics_fee")
  currency       String   @default("TRY")
  notes          String?  @db.Text
  status         QuoteStatus @default(PENDING)
  expiresAt      DateTime @default(dbgenerated("(now() + interval '24 hours')")) @map("expires_at")
  counterQuoteId String?  @map("counter_quote_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  message        Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  productListing ProductListing @relation(fields: [productListingId], references: [id], onDelete: Restrict)
  counterQuote   Quote?   @relation("QuoteCounterChain", fields: [counterQuoteId], references: [id], onDelete: SetNull)
  counterOffers  Quote[]  @relation("QuoteCounterChain")

  @@index([status, expiresAt])
  @@index([productListingId])
  @@index([counterQuoteId])
  @@map("quotes")
}

model ProductListingSector {
  id               String         @id @default(cuid())
  productListingId String         @map("product_listing_id")
  sectorId         String         @map("sector_id")
  createdAt        DateTime       @default(now()) @map("created_at")
  productListing   ProductListing @relation(fields: [productListingId], references: [id], onDelete: Cascade)
  sector           Sector         @relation(fields: [sectorId], references: [id], onDelete: Restrict)

  @@unique([productListingId, sectorId])
  @@index([sectorId])
  @@map("product_listing_sectors")
}

model ProductListingMedia {
  id               String                  @id @default(cuid())
  productListingId String                  @map("product_listing_id")
  mediaType        ProductListingMediaType @default(IMAGE) @map("media_type")
  filePath         String                  @map("file_path")
  originalName     String                  @map("original_name")
  mimeType         String                  @map("mime_type")
  fileSize         Int                     @map("file_size")
  displayOrder     Int                     @default(0) @map("display_order")
  createdAt        DateTime                @default(now()) @map("created_at")
  updatedAt        DateTime                @updatedAt @map("updated_at")
  productListing   ProductListing          @relation(fields: [productListingId], references: [id], onDelete: Cascade)

  @@index([productListingId, displayOrder])
  @@map("product_listing_media")
}

enum Role {
  ADMIN
  SUPPLIER
  BUYER
}

enum SupplierCompanyType {
  SAHIS
  LIMITED
  ANONIM
}

enum SupplierApplicationReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SupplierApplicationDocumentType {
  TAX_CERTIFICATE
  SIGNATURE_CIRCULAR
  TRADE_REGISTRY_GAZETTE
  ACTIVITY_CERTIFICATE
}

enum LogisticsAuthorizationDocumentType {
  K1
  K3
  R1
  R2
  L1
  DIGER
}

enum LogisticsMainServiceType {
  PARSIYEL_TASIMA
  KOMPLE_ARAC_FTL
  SOGUK_ZINCIR
  KONTEYNER_GUMRUK
  AGIR_YUK
  DEPOLAMA
}

enum LogisticsServiceRegion {
  TUM_TURKIYE
  BELIRLI_BOLGELER_SEHIRLER
  ULUSLARARASI
}

enum LogisticsFleetCapacity {
  ONE_TO_FIVE
  SIX_TO_TWENTY
  TWENTY_ONE_TO_FIFTY
  FIFTY_PLUS
}

enum LogisticsApplicationReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LogisticsApplicationDocumentType {
  TAX_CERTIFICATE
  SIGNATURE_CIRCULAR
  TRADE_REGISTRY_GAZETTE
  ACTIVITY_CERTIFICATE
  TRANSPORT_LICENSE
}

enum ProductListingStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum ProductListingMediaType {
  IMAGE
  VIDEO
}

enum ProductListingPackageType {
  BOX
  PALLET
  SACK
  OTHER
}

enum ProductListingShippingTime {
  ONE_TO_THREE_DAYS
  THREE_TO_FIVE_DAYS
  ONE_WEEK
  CUSTOM_PRODUCTION
}

enum ProductListingDeliveryMethod {
  CONTRACTED_CARGO
  FREIGHT_FORWARDER
  BUYER_PICKUP
  OWN_VEHICLE
}

enum ConversationStatus {
  ACTIVE
  ARCHIVED
  BLOCKED
}

enum MessageType {
  TEXT
  IMAGE
  FILE
  QUOTE_REQUEST
  QUOTE_OFFER
  QUOTE_ACCEPTED
  QUOTE_REJECTED
  COUNTER_OFFER
}

enum QuoteStatus {
  PENDING
  ACCEPTED
  REJECTED
  COUNTERED
  EXPIRED
  CANCELED
}
