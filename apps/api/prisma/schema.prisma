generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SUPPLIER
  BUYER
}

enum SupplierCompanyType {
  SAHIS
  LIMITED
  ANONIM
}

enum SupplierApplicationReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id           String    @id @default(cuid())
  fullName     String?
  firstName    String?
  lastName     String?
  phoneNumber  String?
  email        String    @unique
  passwordHash String
  role         Role      @default(BUYER)
  isVerified   Boolean   @default(false)
  isActive     Boolean   @default(true)
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  supplierApplication SupplierApplication?

  @@index([email])
  @@index([role])
  @@map("users")
}

model SupplierApplication {
  id              String              @id @default(cuid())
  userId          String              @unique @map("user_id")
  companyName     String              @map("company_name")
  companyType     SupplierCompanyType @map("company_type")
  vknOrTckn       String              @map("vkn_or_tckn")
  taxOffice       String              @map("tax_office")
  mersisNo        String              @map("mersis_no")
  tradeRegistryNo String?             @map("trade_registry_no")
  activitySector  String              @map("activity_sector")
  city            String              @map("city")
  district        String              @map("district")
  referenceCode   String?             @map("reference_code")
  companyIban     String?             @map("company_iban")
  kepAddress      String?             @map("kep_address")
  isEInvoiceTaxpayer Boolean?         @map("is_e_invoice_taxpayer")
  businessPhone   String?             @map("business_phone")
  headquartersAddress String?         @map("headquarters_address")
  warehouseSameAsHeadquarters Boolean? @map("warehouse_same_as_headquarters")
  warehouseAddress String?            @map("warehouse_address")
  contactFirstName String?            @map("contact_first_name")
  contactLastName String?             @map("contact_last_name")
  contactRole     String?             @map("contact_role")
  contactPhone    String?             @map("contact_phone")
  contactEmail    String?             @map("contact_email")
  reviewStatus    SupplierApplicationReviewStatus @default(PENDING) @map("review_status")
  reviewNote      String?             @map("review_note")
  reviewedAt      DateTime?           @map("reviewed_at")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyType])
  @@index([activitySector])
  @@index([reviewStatus])
  @@map("supplier_applications")
}

model Category {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  level     Int
  parentId  String?  @map("parent_id")
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children Category[] @relation("CategoryHierarchy")
  products Product[]

  @@index([level])
  @@index([parentId])
  @@index([isActive])
  @@map("categories")
}

model Sector {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  products Product[]

  @@index([isActive])
  @@map("sectors")
}

model Product {
  id         String   @id @default(cuid())
  name       String
  slug       String   @unique
  categoryId String   @map("category_id")
  sectorId   String?  @map("sector_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  category Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  sector   Sector?  @relation(fields: [sectorId], references: [id], onDelete: SetNull)

  @@index([categoryId])
  @@index([sectorId])
  @@map("products")
}
