generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SUPPLIER
  BUYER
}

model User {
  id           String    @id @default(cuid())
  fullName     String?
  firstName    String?
  lastName     String?
  phoneNumber  String?
  email        String    @unique
  passwordHash String
  role         Role      @default(BUYER)
  isVerified   Boolean   @default(false)
  isActive     Boolean   @default(true)
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([email])
  @@index([role])
  @@map("users")
}
