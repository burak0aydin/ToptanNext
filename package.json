{
  "name": "toptannext",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@8.15.8",
  "scripts": {
    "dev": "node ./scripts/check-dev-ports.mjs && turbo run dev --parallel",
    "dev:fresh": "pnpm --filter web run clean && node ./scripts/check-dev-ports.mjs && turbo run dev --parallel",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "format": "turbo run format"
  },
  "devDependencies": {
    "turbo": "^1.13.4",
    "typescript": "5.4.5"
  }
}
